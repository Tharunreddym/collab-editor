# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# PostgreSQL
DATABASE_URL=postgres://collab:collab@localhost:5432/collab

# Redis
REDIS_URL=redis://localhost:6379

# JWT — change this to a long random string in production!
JWT_SECRET=super-secret-change-me
JWT_EXPIRES=7d

# CORS — URL of the frontend (no trailing slash)
CLIENT_URL=http://localhost:5173

# ── Client (Vite) ─────────────────────────────────────────
# Leave blank in dev (Vite proxy handles it).
# In production set to wss://yourdomain.com
VITE_WS_URL=
